# ThreatScope Configuration
# Copy to .env and fill in values as needed.
# All core features work without any keys — only narration requires an API key.

THREATSCOPE_HOST=127.0.0.1
THREATSCOPE_PORT=8000
THREATSCOPE_DEBUG=false
THREATSCOPE_DEMO=false

# Database (default: ./data/threatscope.db)
# THREATSCOPE_DB_PATH=/path/to/threatscope.db

# Security
# THREATSCOPE_JWT_SECRET=generate-a-strong-secret-here
# THREATSCOPE_CORS_ORIGINS=http://localhost:5173
# THREATSCOPE_RATE_LIMIT=60

# Threat narration (optional — falls back to template-based narratives)
# THREATSCOPE_NARRATION_KEY=your-api-key-here
